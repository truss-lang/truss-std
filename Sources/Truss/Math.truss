public module Math {
    public func max<T: Comparable>(_ a: T, _ b: T) -> T {
        if a >= b {
            a
        } else {
            b
        }
    }
    public func min<T: Comparable>(_ a: T, _ b: T) -> T {
        if a <= b {
            a
        } else {
            b
        }
    }
    public func abs<T: AdditiveArithmetic & Comparable>(_ value: T) -> T {
        if value >= 0 {
            value
        } else {
            -value
        }
    }
}
